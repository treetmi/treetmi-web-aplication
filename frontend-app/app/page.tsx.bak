                  <p className="text-[8px] font-bold text-muted-foreground uppercase tracking-widest italic dark:text-[#A09E96]">{t.home.stats.matches}</p>
                </div>
              </motion.div>
            </div>

            {/* RIGHT COLUMN: HIGHLY INTERACTIVE SMARTPHONE PREVIEW */}
            <motion.div 
