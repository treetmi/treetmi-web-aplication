      <Navbar />
      
      {/* HERO SECTION WITH INTERACTIVE SMARTPHONE GRID */}
      <section className="relative flex-1 py-8 lg:py-16 overflow-hidden">
        {/* Soft background decor icons */}
        <div className="absolute inset-0 pointer-events-none select-none overflow-hidden opacity-[0.02] dark:opacity-[0.05]">
          <Gamepad2 className="absolute top-20 right-[10%] size-64 -rotate-12" />
          <Code className="absolute bottom-20 left-[5%] size-48 rotate-12" />
          <Music className="absolute top-40 left-[15%] size-40 -rotate-6" />
          <Palette className="absolute bottom-40 right-[15%] size-56 rotate-6" />
        </div>

        <div className="container mx-auto px-4 relative z-10">
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
            
            {/* LEFT COLUMN: BRANDING & CALL-TO-ACTIONS */}
            <div className="lg:col-span-7 space-y-6 text-center lg:text-left">
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                className="inline-flex items-center gap-2 bg-black text-[#FFD551] dark:bg-[#FFD551] dark:text-black px-3.5 py-1.5 font-black italic uppercase text-[10px] skew-x-[-8deg] shadow-sm"
              >
                <Rocket className="size-3.5 fill-current" /> 
                <span className="skew-x-[8deg] tracking-widest">{t.home.badge}</span>
              </motion.div>

              <motion.h1 
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                className="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[0.95] uppercase italic text-[#1A1A19] dark:text-[#EAE9E4]"
              >
                {t.home.heroTitlePart1} <br />
                {t.home.heroTitlePart2} <br />
                <span className="relative inline-block bg-[#FFD551] text-black px-4 py-2 mt-2 -skew-x-6 border-2 border-black shadow-[4px_4px_0px_0px_#000000] dark:shadow-none dark:border-none">
                  {t.home.heroTitle2}
                </span>
              </motion.h1>

              <motion.p 
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ delay: 0.2 }}
                className="text-sm md:text-base text-[#706E68] max-w-xl font-bold uppercase italic leading-relaxed mx-auto lg:mx-0 dark:text-[#A09E96]"
              >
                {t.home.heroSubtitle}
              </motion.p>

              {/* Bullet key benefits */}
              <motion.div 
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ delay: 0.25 }}
                className="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2 text-left max-w-lg mx-auto lg:mx-0 text-xs font-black uppercase italic text-[#1A1A19] dark:text-[#EAE9E4]"
              >
                <div className="flex items-center gap-2">
                  <div className="h-5 w-5 rounded-full bg-green-500/10 border border-green-500 text-green-500 flex items-center justify-center">
                    <CheckCircle2 className="size-3.5 fill-current" />
                  </div>
                  <span>{t.home.benefits.fee}</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="h-5 w-5 rounded-full bg-green-500/10 border border-green-500 text-green-500 flex items-center justify-center">
                    <CheckCircle2 className="size-3.5 fill-current" />
                  </div>
                  <span>{t.home.benefits.widget}</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="h-5 w-5 rounded-full bg-green-500/10 border border-green-500 text-green-500 flex items-center justify-center">
                    <CheckCircle2 className="size-3.5 fill-current" />
                  </div>
                  <span>{t.home.benefits.payment}</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="h-5 w-5 rounded-full bg-green-500/10 border border-green-500 text-green-500 flex items-center justify-center">
                    <CheckCircle2 className="size-3.5 fill-current" />
                  </div>
                  <span>{t.home.benefits.mockup}</span>
                </div>
              </motion.div>

              <motion.div 
