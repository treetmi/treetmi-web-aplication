          <div className="flex gap-6 text-[10px] font-black uppercase italic text-muted-foreground dark:text-[#A09E96]">
            <Link href="#" className="hover:text-[#FFD551]">Legal</Link>
            <Link href="#" className="hover:text-[#FFD551]">Privacy Policy</Link>
            <Link href="#" className="hover:text-[#FFD551]">Contact Support</Link>
          </div>
          <p className="text-[8px] font-black italic text-muted-foreground dark:text-[#A09E96]">© 2026 TREETMI.ID. ALL RIGHTS RESERVED.</p>
        </div>
      </footer>
