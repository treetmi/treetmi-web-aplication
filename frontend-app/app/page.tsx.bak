              animate={{ opacity: 1, scale: 1, y: 0 }}
              transition={{ type: "spring", stiffness: 60, damping: 15, delay: 0.2 }}
              className="lg:col-span-5 flex justify-center lg:justify-end pr-0 lg:pr-6"
