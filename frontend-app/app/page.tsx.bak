                    {t.common.getStarted} <ArrowRight className="ml-2 size-5" />
                  </Button>
                </Link>
                <Link href="/budigamer">
                  <Button variant="outline" className="h-14 px-8 text-lg rounded-2xl border-2 border-black bg-white text-black font-black uppercase italic shadow-[4px_4px_0px_0px_#000000] hover:bg-[#F8F7F3] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[2px_2px_0px_0px_#000000] transition-all dark:bg-[#1C1C1C] dark:text-white dark:border-white dark:shadow-none">
                    {t.common.browseCreators}
                  </Button>
                </Link>
              </motion.div>

              {/* Real-time stats */}
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ delay: 0.4 }}
                className="pt-6 grid grid-cols-3 gap-4 border-t border-[#EAE9E4] dark:border-[#262626] max-w-md mx-auto lg:mx-0"
              >
                <div>
                  <h4 className="text-xl md:text-2xl font-black italic text-[#1A1A19] dark:text-[#EAE9E4]">10K+</h4>
                  <p className="text-[8px] font-bold text-muted-foreground uppercase tracking-widest italic dark:text-[#A09E96]">{t.home.stats.creators}</p>
                </div>
                <div>
                  <h4 className="text-xl md:text-2xl font-black italic text-[#1A1A19] dark:text-[#EAE9E4]">Rp 5M+</h4>
                  <p className="text-[8px] font-bold text-muted-foreground uppercase tracking-widest italic dark:text-[#A09E96]">{t.home.stats.donations}</p>
                </div>
                <div>
