              {/* SMARTPHONE WRAPPER CSS FRAME */}
              <div className="relative w-full max-w-[390px] aspect-[9/19.2] bg-black rounded-[46px] p-2.5 shadow-[0_25px_60px_rgba(0,0,0,0.12)] border-4 border-[#1A1A19] ring-8 ring-black ring-opacity-10 dark:shadow-[0_25px_60px_rgba(255,255,255,0.02)] dark:border-[#262626]">
                {/* Speaker Ear Notch */}
                <div className="absolute top-0 left-1/2 -translate-x-1/2 h-5 w-32 bg-black rounded-b-2xl z-40 flex items-center justify-center">
                  <div className="h-1 w-12 bg-[#2D2D2D] rounded-full" />
                </div>
                
                {/* Screen internal container */}
                <div className="w-full h-full rounded-[38px] overflow-hidden bg-[#FAF9F6] flex flex-col relative dark:bg-[#141414]">
                  {/* Status Bar Mock */}
                  <div className="h-6 px-6 bg-[#FAF9F6] flex justify-between items-center text-[9px] font-black text-[#1A1A19]/50 select-none pointer-events-none z-30 transition-colors dark:bg-[#141414] dark:text-[#EAE9E4]/40 pt-1">
                    <span>09:41</span>
                    <div className="flex items-center gap-1">
                      <Sparkles className="size-2 text-[#FFD551] fill-current" />
                      <span>Treetmi Demo</span>
                    </div>
                  </div>
                  
                  {/* Reusable Profile View inside Phone Frame */}
                  <div className="flex-1 overflow-hidden">
                    <CreatorProfileView username="budigamer" isPreview={true} />
                  </div>
                </div>
              </div>
            </motion.div>

          </div>
        </div>
      </section>

      {/* SUPPORTED PAYMENT CHANNEL SLIDER */}
      <section className="bg-white py-12 border-y border-[#EAE9E4] dark:bg-[#101010] dark:border-[#262626] relative overflow-hidden">
        <div className="absolute top-0 left-1/2 -translate-x-1/2 bg-black text-[#FFD551] dark:bg-[#FFD551] dark:text-black px-5 py-1 text-[8px] font-black italic uppercase tracking-[0.2em] z-10 shadow-sm skew-x-[-6deg]">
          Supported Payment Channels
        </div>
        
        <div className="container mx-auto px-4 relative mt-2">
          <div className="max-w-4xl mx-auto overflow-hidden">
            <motion.div 
              animate={{ x: `-${currentSlide * 100}%` }}
              transition={{ type: "spring", stiffness: 90, damping: 20 }}
              className="flex"
            >
              {Array.from({ length: totalSlides }).map((_, slideIdx) => (
                <div key={slideIdx} className="min-w-full grid grid-cols-5 gap-6 items-center justify-items-center px-4">
                  {paymentLogos.slice(slideIdx * itemsPerSlide, (slideIdx + 1) * itemsPerSlide).map((logo, i) => (
                    <motion.div 
                      key={i} 
                      initial={{ opacity: 0, scale: 0.9 }}
                      whileInView={{ opacity: 1, scale: 1 }}
                      transition={{ delay: i * 0.05 }}
                      className="group"
                    >
                      <img 
                        src={logo.url} 
                        alt={logo.name} 
                        className="h-10 md:h-12 w-auto object-contain transition-transform duration-500 group-hover:scale-105 filter grayscale hover:grayscale-0 dark:brightness-90 dark:contrast-125"
                      />
                    </motion.div>
                  ))}
                </div>
              ))}
            </motion.div>
          </div>

          <div className="flex justify-center gap-2 mt-6">
            {Array.from({ length: totalSlides }).map((_, i) => (
